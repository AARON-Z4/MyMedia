        {
          "name": "Delete Project",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base}}/projects/{{projectId}}",
              "host": ["{{base}}"],
              "path": ["projects", "{{projectId}}"]
            },
            "description": "Deletes a project **and all its associated tasks** (cascading delete).\n\n⚠️ Run this last — once deleted, `projectId` will no longer be valid for task requests."
          },
          "response": [
            {
              "name": "200 OK",
              "originalRequest": {
                "method": "DELETE",
                "url": { "raw": "{{base}}/projects/{{projectId}}" }
              },
              "status": "OK",
              "code": 200,
              "body": "{\n  \"message\": \"Project deleted\"\n}"
            },
            {
              "name": "404 Not Found",
              "originalRequest": {
                "method": "DELETE",
                "url": { "raw": "{{base}}/projects/000000000000000000000000" }
              },
              "status": "Not Found",
              "code": 404,
              "body": "{\n  \"error\": \"Project not found\"\n}"
            }
          ],
          "event": [
