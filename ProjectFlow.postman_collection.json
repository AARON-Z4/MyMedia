    {
      "name": "✅ Tasks",
      "description": "Task operations scoped to a project. Use `GET /projects/:project_id/tasks` with query params to filter by status and sort by due_date.\n\nThe **Create Task** request auto-saves `taskId` for Update and Delete requests.",
      "item": [
        {
          "name": "Create Task",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base}}/projects/{{projectId}}/tasks",
              "host": ["{{base}}"],
              "path": ["projects", "{{projectId}}", "tasks"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Design Mockups\",\n  \"description\": \"Figma wireframes for all screens\",\n  \"status\": \"todo\",\n  \"priority\": \"high\",\n  \"due_date\": \"2026-06-15\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Creates a new task under the specified project.\n\n**Required:** `title`\n\n**Optional:**\n- `description` — string\n- `status` — `todo` | `in-progress` | `done` (default: `todo`)\n- `priority` — `low` | `medium` | `high` (default: `medium`)\n- `due_date` — ISO 8601 date string (e.g. `2026-06-15`)\n\nThe test script auto-saves the new task's `_id` to `taskId`."
          },
          "response": [
            {
              "name": "201 Created",
              "originalRequest": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "url": { "raw": "{{base}}/projects/{{projectId}}/tasks" },
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"title\": \"Design Mockups\",\n  \"description\": \"Figma wireframes\",\n  \"status\": \"todo\",\n  \"priority\": \"high\",\n  \"due_date\": \"2026-06-15\"\n}"
                }
              },
              "status": "Created",
              "code": 201,
              "body": "{\n  \"_id\": \"664f1a2b3c4d5e6f7a8b9c0e\",\n  \"project_id\": \"664f1a2b3c4d5e6f7a8b9c0d\",\n  \"title\": \"Design Mockups\",\n  \"description\": \"Figma wireframes for all screens\",\n  \"status\": \"todo\",\n  \"priority\": \"high\",\n  \"due_date\": \"2026-06-15T00:00:00.000Z\",\n  \"created_at\": \"2026-04-10T08:00:00.000Z\"\n}"
            },
            {
              "name": "400 Validation Error — missing title",
              "originalRequest": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "url": { "raw": "{{base}}/projects/{{projectId}}/tasks" },
                "body": { "mode": "raw", "raw": "{\n  \"status\": \"todo\"\n}" }
              },
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"error\": \"Validation failed\",\n  \"details\": [\n    {\n      \"type\": \"field\",\n      \"msg\": \"Title is required\",\n      \"path\": \"title\",\n      \"location\": \"body\"\n    }\n  ]\n}"
            },
            {
              "name": "400 Validation Error — invalid status",
              "originalRequest": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "url": { "raw": "{{base}}/projects/{{projectId}}/tasks" },
                "body": { "mode": "raw", "raw": "{\n  \"title\": \"Test\",\n  \"status\": \"invalid-value\"\n}" }
              },
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"error\": \"Validation failed\",\n  \"details\": [\n    {\n      \"type\": \"field\",\n      \"msg\": \"Invalid status\",\n      \"path\": \"status\",\n      \"location\": \"body\"\n    }\n  ]\n}"
            },
            {
              "name": "404 Project Not Found",
              "originalRequest": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "url": { "raw": "{{base}}/projects/000000000000000000000000/tasks" },
                "body": { "mode": "raw", "raw": "{\n  \"title\": \"Test task\"\n}" }
