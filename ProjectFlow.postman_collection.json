                { "key": "limit", "value": "10", "description": "Items per page (default: 10, max: 100)" }
              ]
            },
            "description": "Returns a paginated list of all projects, sorted by most recently created.\n\n**Query params:**\n- `page` — page number (default: 1)\n- `limit` — items per page (default: 10, max: 100)"
          },
          "response": [
            {
              "name": "200 OK",
              "originalRequest": {
                "method": "GET",
                "url": { "raw": "{{base}}/projects?page=1&limit=10" }
              },
              "status": "OK",
              "code": 200,
              "body": "{\n  \"data\": [\n    {\n      \"_id\": \"664f1a2b3c4d5e6f7a8b9c0d\",\n      \"name\": \"Website Redesign\",\n      \"description\": \"Full company website overhaul\",\n      \"created_at\": \"2026-04-10T08:00:00.000Z\"\n    }\n  ],\n  \"pagination\": {\n    \"page\": 1,\n    \"limit\": 10,\n    \"total\": 1,\n    \"pages\": 1\n  }\n}"
